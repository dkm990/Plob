# Auto detect text files and perform LF normalization
* text=auto
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.sh text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
